{
  "name": "server",
  "version": "1.0.0",
  "description": "Prowider Mini Lead Distribution System - Express API",
  "main": "api/index.mjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsup src/index.ts --format esm --platform node --target node25 --outDir api --external pg-native",
    "start": "node api/index.mjs",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "vercel-build": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "ts-node src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "tsup": "^8.5.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/uuid": "^10.0.0",
    "prisma": "5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
